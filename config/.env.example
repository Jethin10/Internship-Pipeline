# Internship Pipeline — environment configuration
# Copy this file to  config/.env  and fill in your values.
# Secrets live here, never in code or the database.

# --- LLM (model & gateway agnostic, via LiteLLM) ------------------------------
# LiteLLM model naming:
#   claude-opus-4-8 · claude-sonnet-4-6 · gpt-4o · gemini/gemini-1.5-pro
#   openrouter/<model> · openai/<model> (against custom base_url)
#
# --- Pick one provider below; comment out the rest ---
#
# Option A: OpenRouter (multi-provider gateway — free models available)
#   Sign up at https://openrouter.ai/ → API Keys
LLM_MODEL=openrouter/moonshotai/kimi-k2.6:free
LLM_API_KEY=sk-or-v1-your-key-here
LLM_API_BASE=https://openrouter.ai/api/v1

# Option B: Anthropic Claude (direct)
# LLM_MODEL=claude-opus-4-8
# LLM_API_KEY=sk-ant-your-key-here
# LLM_API_BASE=

# Option C: OpenAI (direct)
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-your-key-here
# LLM_API_BASE=

# Option D: Google Gemini
# LLM_MODEL=gemini/gemini-1.5-pro
# LLM_API_KEY=your-key-here
# LLM_API_BASE=

LLM_TEMPERATURE=0.4

# --- storage -------------------------------------------------------------
# DB_PATH=data/piperline.db

# --- matching ------------------------------------------------------------
FIT_THRESHOLD=0.6
# deterministic-only runs (--no-llm) use a gentler cutoff as a rough prefilter
DETERMINISTIC_FIT_THRESHOLD=0.25

# --- safety switches (keep OFF until you trust each stage) ---------------
AUTOPILOT_APPLY=false
AUTOPILOT_OUTREACH=false
MAX_OUTREACH_PER_DAY=20

# --- aggregator ----------------------------------------------------------
DEFAULT_COUNTRY_INDEED=usa
# PROXIES=http://user:pass@host:port,http://host2:port

# --- outreach email (SMTP) -----------------------------------------------
# For Gmail: use an app password from https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password-here
